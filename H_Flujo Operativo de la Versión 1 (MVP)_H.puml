@startuml
title SGOI - Flujo Operativo MVP

skinparam shadowing false
skinparam roundcorner 18
skinparam defaultTextAlignment center
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #555555
}

' ===== FILA 1 =====
rectangle "1. Preparación de datos" as F1 {
  rectangle "Importar\nExcel/TAT" as A1
  rectangle "Normalizar\ndatos" as A2
  rectangle "Catálogo\nPART" as A3
  rectangle "Activos\nASSET" as A4
  rectangle "Códigos\ninternos / QR" as A5

  A1 -right-> A2
  A2 -right-> A3
  A3 -right-> A4
  A4 -right-> A5
}

' ===== FILA 2 =====
rectangle "2. Reporte en campo" as F2 {
  rectangle "Nuevo reporte\nTécnico" as B1
  rectangle "Tipo de\nevento" as B2
  rectangle "Datos del\nservicio" as B3
  rectangle "Escanear QR /\ncódigo de barras" as B4
  rectangle "Validar\nequipo" as B5
  rectangle "Asociar equipo\nal reporte" as B6

  B1 -right-> B2
  B2 -right-> B3
  B3 -right-> B4
  B4 -right-> B5
  B5 -right-> B6
}

' ===== FILA 3 =====
rectangle "3. Evidencia y cierre" as F3 {
  rectangle "Adjuntar\nfotografías" as C1
  rectangle "Guardar\nreporte" as C2
  rectangle "Actualizar\nestado" as C3
  rectangle "Actualizar\nubicación" as C4
  rectangle "Registrar\nhistorial" as C5

  C1 -right-> C2
  C2 -right-> C3
  C3 -right-> C4
  C4 -right-> C5
}

' ===== FILA 4 =====
rectangle "4. Salida" as F4 {
  rectangle "Generar PDF\nestándar" as D1
  rectangle "Consultar reportes\ne inventario" as D2

  D1 -right-> D2
}

A5 -down-> B1
B6 -down-> C1
C5 -down-> D1

note right of B2
Instalación
Desinstalación
Soporte técnico
Soporte remoto
Reemplazo
Envío desde base
Recepción en campo
end note

note right of D1
Incluye:
- trabajo realizado
- inventario asociado
- fotografías
end note

@enduml